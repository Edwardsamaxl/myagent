MODEL_PROVIDER=ollama
MODEL_NAME=qwen2.5:7b

OLLAMA_BASE_URL=http://localhost:11434
# 如果你的 Ollama 在其他端口（例如 11435），改这里即可
# OLLAMA_BASE_URL=http://127.0.0.1:11435

OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=

MAX_STEPS=6
TEMPERATURE=0.2
MAX_TOKENS=768

WEB_HOST=127.0.0.1
WEB_PORT=7860
# 可选：跨域调用 API 时设置，例如 http://localhost:5173 或 *
# WEB_CORS_ORIGINS=

DATA_DIR=./runtime
WORKSPACE_DIR=./workspace

RAG_ENABLED=true
CHUNK_SIZE=500
CHUNK_OVERLAP=80
RETRIEVAL_TOP_K=6
RERANK_TOP_K=3
RERANK_CASCADE=false
RERANKER_PROVIDER=huggingface
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=http://localhost:11434
RETRIEVAL_FUSION_MODE=weighted_sum
RETRIEVAL_LEXICAL_WEIGHT=0.35
RETRIEVAL_TFIDF_WEIGHT=0.25
RETRIEVAL_EMBEDDING_WEIGHT=0.40
EMBEDDING_ENABLED=true
# 可选：留空时跟随 MODEL_PROVIDER
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_TOP_K=12

# 生成策略（可选，默认使用代码内阈值）
# GENERATION_STRICT_POLICY=1
# GENERATION_REFUSE_COVERAGE_THRESHOLD=0.10
# GENERATION_CAUTIOUS_COVERAGE_THRESHOLD=0.22
# GENERATION_MAX_EVIDENCE=3

# 评测脚本是否强制使用 mock（默认 false，建议保持 false）
EVAL_USE_MOCK=false
